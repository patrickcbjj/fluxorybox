# Copie para .env e preencha.

# Porta (local). Na Discloud é injetada automaticamente.
PORT=3000

# Chave mestra p/ criptografar senhas (base64 de 32 bytes).
# Gere: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MASTER_KEY=

# Token de acesso à API (Bearer). Deixe vazio só em dev local.
API_TOKEN=

# Caminho do SQLite.
DB_PATH=./data/mail.db

# Contas semeadas (JSON) — sobrevivem a redeploys na Discloud.
# SEED_ACCOUNTS=[{"email":"voce@gmail.com","password":"senha-de-app","displayName":"Você"}]
SEED_ACCOUNTS=
